# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored.

# Supabase project URL (from Supabase Studio → Settings → Data API)
# Example: https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key — safe to expose to the browser.
# From Settings → Data API → Project API keys → "anon public".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — NEVER expose to the browser.
# Used server-side for admin operations (creating employee accounts, banning users).
# From Settings → Data API → Project API keys → "service_role secret".
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for magic-link redirects.
# Local dev: http://localhost:3000
# Production: https://app.keylinktransport.ca
NEXT_PUBLIC_SITE_URL=http://localhost:3000
